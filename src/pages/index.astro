---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import BlogPostCard from '@components/BlogPostCard.astro';

const publishedPosts = await getCollection('blog', ({ data }) => !data.isDraft);
const posts = publishedPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout>
  <section aria-label="Blog Posts">
    {posts.map(({ body, data, id }) => <BlogPostCard title={data.title} publishDate={data.publishDate} target={`/blog/${id}`} content={body!} />)}
  </section>
</BaseLayout>

<style>
  section {
    display: grid;
    row-gap: 1.5rem;
  }
</style>
